{
  "expo": {
    "name": "ORA Shop",
    "slug": "ora-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ora.shop",
      "infoPlist": {
        "NSCameraUsageDescription": "ORA needs camera access to scan customer QR codes for booking verification."
      },
      "scheme": "ora",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.ora.shop",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Fashcycle Shop to access your camera for QR code scanning."
        }
      ],
      "expo-secure-store"
    ]
  }
}