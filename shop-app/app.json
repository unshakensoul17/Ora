{
  "expo": {
    "name": "ORA Shop",
    "slug": "ora-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#022b1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ora.shop",
      "infoPlist": {
        "NSCameraUsageDescription": "ORA needs camera access to scan customer QR codes for booking verification."
      },
      "scheme": "ora",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.ora.shop",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#022b1e"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Ora Shop to access your camera for QR code scanning."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "8485aa6e-a88f-408c-bbe8-1d11ecfce5ff"
      }
    }
  }
}
