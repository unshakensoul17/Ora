# ============================================
# ORA BACKEND - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# CORE
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
# Get these from: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ============================================
# SUPABASE (Storage & Optional Auth)
# ============================================
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# REDIS (Upstash)
# ============================================
# Get these from: Upstash Console → Redis → Database Details
UPSTASH_REDIS_REST_URL=https://apn1-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxx

# ============================================
# SEARCH (MeiliSearch)
# ============================================
# Your MeiliSearch instance URL (Railway or self-hosted)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-master-key

# ============================================
# AUTH
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=10

# ============================================
# PAYMENTS (Razorpay)
# ============================================
# Get these from: Razorpay Dashboard → Settings → API Keys
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# ============================================
# EXTERNAL APIS
# ============================================
# Google Maps API Key (enable Maps JavaScript API, Places API)
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxx

# ============================================
# APP CONFIG
# ============================================
HOLD_DURATION_HOURS=48
HOLD_DEPOSIT_AMOUNT=99
LEAD_FEE_AMOUNT=100

# ============================================
# CORS (comma-separated allowed origins)
# ============================================
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,https://ora-user-web.vercel.app,https://ora-admin.vercel.app
