generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  name          String?
  email         String?   @unique
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  city          String?
  emailVerified Boolean   @default(false)
  passwordHash  String?
  bookings      Booking[]
  reviews       Review[]

  @@index([phone])
  @@index([email])
}

model Shop {
  id                     String                  @id @default(uuid())
  name                   String
  ownerName              String
  ownerPhone             String                  @unique
  email                  String                  @unique
  address                String
  locality               String
  city                   String                  @default("Indore")
  pincode                String
  lat                    Float
  lng                    Float
  status                 ShopStatus              @default(PENDING)
  tier                   PricingTier             @default(STARTER)
  description            String?
  images                 String[]
  operatingHours         Json?
  verifiedAt             DateTime?
  suspendedAt            DateTime?
  suspendReason          String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          Boolean                 @default(false)
  lastLoginAt            DateTime?
  passwordChangedAt      DateTime?
  passwordHash           String
  attributions           AttributionEvent[]
  bookings               Booking[]
  inventoryItems         InventoryItem[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  reviews                Review[]
  supportTickets         SupportTicket[]

  @@index([ownerPhone])
  @@index([email])
  @@index([status])
  @@index([locality])
  @@index([city, locality])
}

model InventoryItem {
  id              String              @id @default(uuid())
  shopId          String
  sku             String?
  name            String
  description     String?
  category        Category
  subcategory     String?
  color           String?
  size            String
  sizeDetails     Json?
  rentalPrice     Int
  retailPrice     Int?
  securityDeposit Int
  images          String[]
  occasion        String[]
  brand           String?
  status          ItemStatus          @default(ACTIVE)
  condition       ItemCondition       @default(EXCELLENT)
  timesRented     Int                 @default(0)
  lastRentedAt    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  blocks          AvailabilityBlock[]
  bookings        Booking[]
  shop            Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reviews         Review[]

  @@index([shopId])
  @@index([category])
  @@index([status])
  @@index([size])
  @@index([shopId, category])
  @@index([rentalPrice])
  @@index([timesRented])
}

model AvailabilityBlock {
  id        String        @id @default(uuid())
  itemId    String
  date      DateTime      @db.Date
  reason    BlockReason
  bookingId String?
  notes     String?
  createdAt DateTime      @default(now())
  booking   Booking?      @relation(fields: [bookingId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, date])
  @@index([itemId, date])
  @@index([bookingId])
}

model Booking {
  id             String              @id @default(uuid())
  userId         String?
  itemId         String
  startDate      DateTime            @db.Date
  endDate        DateTime            @db.Date
  status         BookingStatus       @default(HOLD)
  qrCodeHash     String?             @unique
  qrCodeUrl      String?
  platformPrice  Int?
  depositAmount  Int?
  depositPaid    Boolean             @default(false)
  holdExpiresAt  DateTime?
  verifiedAt     DateTime?
  pickedUpAt     DateTime?
  returnedAt     DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  shopId         String
  customerName   String?
  customerPhone  String?
  source         BookingSource       @default(WEB_LEAD)
  customerId     String?
  discountAmount Int                 @default(0)
  attribution    AttributionEvent?
  blocks         AvailabilityBlock[]
  customer       Customer?           @relation(fields: [customerId], references: [id])
  item           InventoryItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  shop           Shop                @relation(fields: [shopId], references: [id])
  user           User?               @relation(fields: [userId], references: [id])
  payments       Payment[]
  review         Review?
  discountType   DiscountType?
  discountValue  Int?
  conditionImages ItemConditionImage[]

  @@index([userId])
  @@index([customerId])
  @@index([itemId])
  @@index([shopId])
  @@index([status])
  @@index([qrCodeHash])
  @@index([holdExpiresAt])
  @@index([startDate, endDate])
  @@index([shopId, status])
}

model AttributionEvent {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  shopId       String
  scannedAt    DateTime  @default(now())
  scannedBy    String?
  deviceInfo   String?
  billable     Boolean   @default(true)
  billedAt     DateTime?
  billedAmount Int?
  booking      Booking   @relation(fields: [bookingId], references: [id])
  shop         Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([billable])
  @@index([scannedAt])
}

model ShopBilling {
  id                String      @id @default(uuid())
  shopId            String      @unique
  currentTier       PricingTier @default(STARTER)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  razorpaySubId     String?
  totalLeads        Int         @default(0)
  billedLeads       Int         @default(0)
  pendingAmount     Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  actorType  String
  actorId    String?
  changes    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Review {
  id        String        @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  shopId    String
  itemId    String
  bookingId String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  images    String[]
  booking   Booking       @relation(fields: [bookingId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  shop      Shop          @relation(fields: [shopId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([itemId])
  @@index([userId])
}

model SupportTicket {
  id         String          @id @default(uuid())
  shopId     String
  category   SupportCategory @default(GENERAL)
  subject    String
  message    String
  status     TicketStatus    @default(OPEN)
  priority   TicketPriority  @default(NORMAL)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  resolvedAt DateTime?
  shop       Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([status])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  shopId       String   @unique
  pushEnabled  Boolean  @default(true)
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  newHolds     Boolean  @default(true)
  pickups      Boolean  @default(true)
  returns      Boolean  @default(true)
  marketing    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Notification {
  id        String           @id @default(uuid())
  shopId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  shop      Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, isRead])
}

model Customer {
  id            String    @id @default(uuid())
  shopId        String
  name          String
  phone         String    @unique
  email         String?
  notes         String?
  isBlacklisted Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  address       String?
  bookings      Booking[]

  @@index([shopId])
  @@index([phone])
}

model Payment {
  id         String        @id @default(uuid())
  bookingId  String
  amount     Int
  type       PaymentType
  method     PaymentMethod
  status     PaymentStatus @default(COMPLETED)
  referenceId String?      // Added
  notes      String?
  recordedAt DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  Booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("PaymentRecord")
}

model ItemConditionImage {
  id          String             @id @default(uuid())
  bookingId   String
  booking     Booking            @relation(fields: [bookingId], references: [id])
  url         String
  type        ImageConditionType
  capturedAt  DateTime           @default(now())

  @@index([bookingId])
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum ImageConditionType {
  PRE_RENTAL
  POST_RENTAL
}

enum ShopStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum PricingTier {
  STARTER
  PRO
}

enum Category {
  LEHENGA
  SHERWANI
  SAREE
  ANARKALI
  INDO_WESTERN
  GOWN
  KURTA_PAJAMA
  ACCESSORIES
}

enum ItemStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum ItemCondition {
  EXCELLENT
  GOOD
  FAIR
}

enum BlockReason {
  RENTAL
  PICKUP
  RETURN
  MAINTENANCE
  HOLD
}

enum BookingStatus {
  HOLD
  CONFIRMED
  RENTED
  RETURNED
  CANCELLED
  DISPUTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupportCategory {
  GENERAL
  TECHNICAL
  BILLING
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationType {
  NEW_HOLD
  PICKUP_REMINDER
  RETURN_REMINDER
  PAYMENT_RECEIVED
  SYSTEM_UPDATE
  MARKETING
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum PaymentType {
  DEPOSIT
  RENTAL
  LATE_FEE
  DAMAGE_FEE
  REFUND
  ADVANCE
  FULL
  BALANCE
}

enum BookingSource {
  WEB_LEAD
  WALK_IN
  PHONE
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  SUCCESS
}
